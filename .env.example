HOST=127.0.0.1
PORT=3187
DATABASE_PATH=./data/nami-mail.db
MASTER_KEY_PATH=./data/master.key
SYNC_MESSAGE_LIMIT=200
LOG_LEVEL=info

# Desktop OAuth configuration: the installed Windows app reads only the four
# settings below from %APPDATA%\Nami Mail\nami-mail.env. The development
# desktop app uses its project-root .env only as a fallback after that file.
# OS environment variables supplied when Nami Mail starts take precedence.
# The installed file cannot set HOST, PORT, database, or key paths.
# These are public client IDs, tenant, and TTL only; never put a client secret
# in this desktop or loopback application.
# Google must use a Google Cloud Desktop app client and the runtime callback is
# http://127.0.0.1:<dynamic-port>/api/oauth/google/callback.
# Microsoft must use a Mobile and desktop applications/public client with a
# registered http://localhost loopback redirect. Its runtime callback is
# http://localhost:<dynamic-port>/api/oauth/microsoft/callback via IPv6 ::1.
NAMI_MAIL_GOOGLE_OAUTH_CLIENT_ID=
NAMI_MAIL_MICROSOFT_OAUTH_CLIENT_ID=
# Microsoft Entra tenant: common, organizations, consumers, or a tenant ID.
NAMI_MAIL_MICROSOFT_TENANT=common
# Pending authorization lifetime in seconds (60-900).
NAMI_MAIL_OAUTH_FLOW_TTL_SECONDS=600
