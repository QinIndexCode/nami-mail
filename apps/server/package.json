{
  "name": "@nami/server",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/build-locale-catalog.mjs",
    "dev": "node ../../scripts/run-server-node.mjs --watch",
    "prebuild": "node ../../scripts/build-locale-catalog.mjs",
    "build": "tsc -p tsconfig.json",
    "start": "node ../../scripts/run-server-node.mjs --start",
    "pretest": "node ../../scripts/build-locale-catalog.mjs --check",
    "test": "node ../../scripts/run-server-tests.mjs",
    "pretypecheck": "node ../../scripts/build-locale-catalog.mjs --check",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "better-sqlite3": "^13.0.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.10.0",
    "imapflow": "^1.4.8",
    "mailparser": "^3.9.14",
    "nodemailer": "^9.0.3",
    "oauth4webapi": "^3.8.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "tsx": "^4.20.6",
    "typescript": "^7.0.2",
    "vitest": "^4.0.18"
  }
}
